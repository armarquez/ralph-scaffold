#!/usr/bin/env bash
# pre-commit hook: runs checks before allowing a commit.
# Prefers `just check` when a justfile is present; falls back to .ralphrc.json test_cmd.
set -euo pipefail

# Prefer `just check` if a justfile is present
if [ -f "justfile" ] || [ -f "Justfile" ]; then
    echo "[ralph] running: just check"
    if ! just check; then
        echo ""
        echo "[ralph] COMMIT BLOCKED: just check failed."
        echo "[ralph] Fix the failures above, then retry your commit."
        exit 1
    fi
    echo "[ralph] checks passed — commit allowed"
    exit 0
fi

# Fallback: read test_cmd from .ralphrc.json
RALPHRC=".ralphrc.json"

if [ ! -f "$RALPHRC" ]; then
    echo "[ralph] warning: no justfile and no .ralphrc.json — skipping test gate"
    exit 0
fi

TEST_CMD=$(python3 -c "
import json, sys
try:
    cfg = json.load(open('$RALPHRC'))
    print(cfg.get('test_cmd', ''))
except Exception as e:
    print(f'error reading $RALPHRC: {e}', file=sys.stderr)
    sys.exit(1)
")

if [ -z "$TEST_CMD" ]; then
    echo "[ralph] warning: test_cmd not set in $RALPHRC — skipping test gate"
    exit 0
fi

echo "[ralph] running: $TEST_CMD"
if ! eval "$TEST_CMD"; then
    echo ""
    echo "[ralph] COMMIT BLOCKED: tests failed."
    echo "[ralph] Fix the failures above, then retry your commit."
    exit 1
fi

echo "[ralph] tests passed — commit allowed"
