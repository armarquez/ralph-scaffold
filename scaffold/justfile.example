# justfile — generated by ralph-scaffold
# Replace [PLACEHOLDERS] with your project's actual commands.

# Install all dependencies and wire the pre-commit hook
install:
    [INSTALL COMMAND]          # e.g. uv sync --extra dev / npm install
    cp .ralph/hooks/pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit
    @echo "✓ installed"

# Run tests                    # EDIT THIS
test:
    [TEST COMMAND]             # e.g. uv run pytest --tb=short -q

# Run linter                   # EDIT THIS
lint:
    [LINT COMMAND]             # e.g. uv run ruff check .

# Run lint then tests (required before every commit)
check: lint test

# Run the ralph loop (dry-run by default)
ralph *args="--dry-run":
    python scripts/ralph.py {{args}}

# Show current task status
status:
    RALPH_PRD=prd.json python scripts/task_runner.py status
